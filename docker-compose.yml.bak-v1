services:
  blog:
    build:
      context: .
      args:
        NEXT_PUBLIC_SITE_URL: https://wwjjhh.online
    container_name: blog
    mem_limit: 512m
    cpus: 1.0
    network_mode: host
    environment:
      NODE_ENV: production
      NEXT_TELEMETRY_DISABLED: "1"
      PORT: 3001
      NETDATA_URL: http://127.0.0.1:19999
    env_file:
      - .env
    volumes:
      - ./content:/app/content:ro
    restart: unless-stopped
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:3001/"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 45s
