NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 推荐：单条 MySQL 直连地址。本地和 Vercel 都可以用这一条。
# DATABASE_URL=mysql://learning_blog_user:change_me@127.0.0.1:3306/learning_blog

# 或者使用分项配置。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=learning_blog
MYSQL_USER=learning_blog_user
MYSQL_PASSWORD=<change-me>

# 网页 /write 写入密钥。不要提交真实值。
BLOG_ADMIN_TOKEN=<set-a-long-random-secret>
